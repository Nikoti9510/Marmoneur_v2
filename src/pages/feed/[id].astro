---
import Feed from "../../layouts/Feed.astro";
import { feedSource } from "../../Feeds/feedSources.ts";

export function getStaticPaths() {
  return [...feedSource].map(([key, urls]) => ({
    params: { id: key },
    props: { name: key, urls },
  }));
}

const { name, urls } = Astro.props;
---

<Feed feed={[name, urls]} />