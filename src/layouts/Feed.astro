---
import Layout from "../layouts/Layout.astro";
import Parser from "rss-parser";
const parser = new Parser();

const maxDate = new Date();
maxDate.setDate(maxDate.getDate() - 7);

interface FeedItem {
    feed?: string;
    title?: string;
    link?: string;
    date?: Date;
}
const feedItems: FeedItem[] = [];

const { feed } = Astro.props;
const feedName = feed["0"];
const feedUrls: string[] = feed["1"];

await Promise.allSettled(
    feedUrls.map(async (url) => {
        try {
            const feed = await parser.parseURL(url);
            feed.items.forEach((item) => {
                const date = item.pubDate ? new Date(item.pubDate) : undefined;
                if (date && date >= maxDate) {
                    feedItems.push({
                        feed: feed.title,
                        title: item.title,
                        link: item.link,
                        date,
                    });
                }
            });
        } catch (error) {
            console.error(`Error fetching feed from ${feedUrls}:`, error);
        }
    }),
);

const sortedFeedItems = feedItems.sort(
    (a, b) =>
        (b.date ?? new Date()).getTime() - (a.date ?? new Date()).getTime(),
);
---

<Layout>
    <header class="title">
        <a class="back" href="/"
            ><span class="arrow">←</span><span>Retour à l'accueil</span></a
        >
    </header>
    <div class="feedContainer">
        {
            sortedFeedItems.map((item) => (
                <ul>
                    <li>
                        <a href={item.link}>{item.title}</a>
                        <p>{item.feed}</p>
                        <p>{item.date}</p>
                    </li>
                </ul>
            ))
        }
    </div>
</Layout>
